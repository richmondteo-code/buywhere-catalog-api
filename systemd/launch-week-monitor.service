[Unit]
Description=BuyWhere launch week health monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
User=paperclip
WorkingDirectory=/home/paperclip/buywhere-api
EnvironmentFile=-/etc/buywhere/api-healthcheck.env
ExecStart=/usr/bin/env python3 /home/paperclip/buywhere-api/scripts/monitoring/launch_week_monitor.py --once
StandardOutput=append:/home/paperclip/buywhere-api/logs/launch_week_monitor/systemd.log
StandardError=append:/home/paperclip/buywhere-api/logs/launch_week_monitor/systemd.log

[Install]
WantedBy=multi-user.target