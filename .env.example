# Database (PostgreSQL)
# For production, use Neon PostgreSQL or self-hosted
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://buywhere:buywhere@localhost:5432/catalog

# Database Replica (for read scaling)
# Set to replica URL to enable read/write splitting
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_REPLICA_URL=postgresql+asyncpg://buywhere:buywhere@localhost:5433/catalog

# PgBouncer connection (optional - for connection pooling)
# Routes through PgBouncer for pooled connections
# Format: postgresql+asyncpg://user:password@host:port/database
PGBOUNCER_URL=postgresql+asyncpg://buywhere:buywhere@localhost:5435/catalog

# PostgreSQL credentials (used by docker-compose)
POSTGRES_USER=buywhere
POSTGRES_PASSWORD=buywhere

# Replication slot name (must match between primary and replica)
REPLICA_SLOT_NAME=replica_slot

# Redis
# Format: redis://host:port/db
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET_KEY=change-me-to-a-strong-random-secret-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=525600

# Rate limiting
RATE_LIMIT_PER_MINUTE=1000

# App
APP_VERSION=1.0.0
ENVIRONMENT=production
DEBUG=false

# Public URL (Cloudflare tunnel or custom domain)
# Update this when the tunnel restarts — URL is ephemeral
PUBLIC_URL=https://api.buywhere.ai

# Optional: Scraping pipeline
# SCRAPER_TYPE=shopee|lazada|carousell|qoo10|amazon-sg
# LOG_LEVEL=INFO

# PostHog Analytics (free tier at https://posthog.com)
# Create a project, get your API key from Project Settings -> Keys
# POSTHOG_PROJECT_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://app.posthog.com
# Set to "true" to disable PostHog tracking (e.g., in dev environments without a key)
# POSTHOG_DISABLED=false
