{
  "name": "buywhere-api",
  "version": "0.1.0",
  "description": "BuyWhere product catalog API — agent-native",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "dev": "ts-node src/index.ts",
    "dev:mcp": "ts-node src/mcp-server.ts",
    "migrate": "ts-node src/migrate.ts",
    "start:refresh": "node dist/jobs/priceRefreshRunner.js",
    "refresh": "ts-node src/jobs/priceRefreshRunner.ts",
    "test": "node --test src/__tests__/*.test.ts",
    "test:mcp": "node --test src/__tests__/mcp-integration.test.ts",
    "test:mcp:load": "node --test src/__tests__/mcp-load.ts"
  },
  "dependencies": {
    "@sentry/node": "^10.49.0",
    "@aws-sdk/client-ses": "^3.1024.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "pg": "^8.11.3",
    "posthog-node": "^4.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.5",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^9.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
