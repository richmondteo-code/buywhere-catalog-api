{
  "name": "buywhere-api",
  "version": "0.1.0",
  "description": "BuyWhere product catalog API — agent-native",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp-server.js",
    "dev": "ts-node src/index.ts",
    "dev:mcp": "ts-node src/mcp-server.ts",
