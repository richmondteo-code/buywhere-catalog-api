{
  "name": "@buywhere/sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for BuyWhere Agent-Native Product Catalog API",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "eslint src/",
    "test": "vitest"
  },
  "keywords": [
    "buywhere",
    "ecommerce",
    "product-catalog",
    "ai-agents",
    "singapore",
    "shopping"
  ],
  "author": "BuyWhere Engineering",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@types/retry": "^0.12.0",
    "retry": "^0.13.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
